{
  "name": "basaltpass-frontend",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "prepare:build-info": "node ./scripts/generate-build-info.cjs",
    "dev": "npm run dev:user",
    "dev:user": "npm run -w @basaltpass/console-user dev",
    "dev:tenant": "npm run -w @basaltpass/console-tenant dev",
    "dev:admin": "npm run -w @basaltpass/console-admin dev",
    "build": "npm run prepare:build-info && npm run -w @basaltpass/console-user build && npm run -w @basaltpass/console-tenant build && npm run -w @basaltpass/console-admin build",
    "build:user": "npm run prepare:build-info && npm run -w @basaltpass/console-user build",
    "build:tenant": "npm run prepare:build-info && npm run -w @basaltpass/console-tenant build",
    "build:admin": "npm run prepare:build-info && npm run -w @basaltpass/console-admin build",
    "preview:user": "npm run -w @basaltpass/console-user preview",
    "preview:tenant": "npm run -w @basaltpass/console-tenant preview",
    "preview:admin": "npm run -w @basaltpass/console-admin preview"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
